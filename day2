import random

number = random.randint(1, 10)
attempts = 3

while attempts > 0:
    guess = int(input("Enter your guess (1-10): "))

    if guess < number:
        print("Too low")
    elif guess > number:
        print("Too high")
    else:
        print("Correct! You win 🎉")
        break

    attempts -= 1
    print("Attempts left:", attempts)

if attempts == 0:
    print("Game Over 😢 The number was", number)
